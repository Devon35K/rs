# Database Configuration
# Render usually provides a DATABASE_URL. If you use it, you don't need the individual DB_ variables below.
DATABASE_URL=mysql://root:password@localhost:3306/acadportal
DB_HOST=localhost
DB_NAME=acadportal
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Google OAuth Configuration
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
GOOGLE_REDIRECT_URI=http://localhost/rs/index.php?page=google-callback
GOOGLE_ALLOWED_DOMAIN=usep.edu.ph
